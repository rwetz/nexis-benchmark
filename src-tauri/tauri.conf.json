{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nexis Benchmark",
  "version": "0.1.0",
  "identifier": "com.nexis.benchmark",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Nexis Benchmark",
        "width": 1280,
        "height": 820,
        "minWidth": 760,
        "minHeight": 520,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Ryan Wetzstein",
    "category": "DeveloperTool",
    "copyright": "Copyright © 2026 Ryan Wetzstein",
    "shortDescription": "Benchmark local AI models across backends.",
    "longDescription": "Drop in ONNX or GGUF models and compare throughput, latency, memory, and accuracy across ONNX Runtime, llama.cpp, and nexis-ml-rs.",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
